# Firebase Web App Configuration
# Get these values from: Firebase Console > Project Settings > General > Your apps > Web app
# These are safe to expose in client-side code by design (Firebase enforces
# security via Firestore/Storage rules, not by hiding these values).

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Your production site URL (used for canonical URLs, sitemap, and OG tags)
NEXT_PUBLIC_SITE_URL=https://your-project.web.app

# Set to "true" to use local Firebase Emulators during development
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false

# Cloudinary Configuration (used for product image uploads)
# Get these from: Cloudinary Console > Settings > Upload
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET must be an UNSIGNED upload preset.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=j9ks4gjd
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=shopease-upload
